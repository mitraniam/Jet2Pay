# ──────────────────────────────────────────────
# Jet2Pay Backend — Environment Variables
# Copy to .env.local and fill in real values
# ──────────────────────────────────────────────

# PostgreSQL (e.g. Supabase, Neon, Railway Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/jet2pay?schema=public"

# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL="https://YOUR-INSTANCE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# JWT secret for admin endpoints (min 32 chars)
ADMIN_JWT_SECRET="change-me-to-a-random-32-char-string"

# AviationStack API (https://aviationstack.com — free tier available)
AVIATIONSTACK_API_KEY="YOUR_AVIATIONSTACK_KEY"

# Fallback: AirLabs (https://airlabs.co — alternative)
# AIRLABS_API_KEY="YOUR_AIRLABS_KEY"

# CORS — frontend origin(s), comma-separated
ALLOWED_ORIGINS="http://localhost:5173,https://jet2pay.eu"

# App environment
NODE_ENV="development"

# ── Cloudflare R2 Storage (Priority 4) ───────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jet2pay-docs

# ── Resend Email (Priority 5) ────────────────
RESEND_API_KEY=
EMAIL_FROM=claims@jet2pay.eu

# ── Cron Secret (Priority 5) ─────────────────
CRON_SECRET=

# ── Wise / TransferWise (Priority 7) ─────────
WISE_API_KEY=
WISE_PROFILE_ID=
WISE_WEBHOOK_SECRET=
WISE_SANDBOX=true
